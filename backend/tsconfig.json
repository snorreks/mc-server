{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "rootDir": "..",
    "paths": {
      "$logger": ["./src/logger.ts"]
    }
  },
  "include": ["src/**/*.ts", "../config.ts", "../shared/**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
