rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }
    match /ag-server/status {
      allow read: if true;
      allow write: if false;
    }
    match /ag-server/allowed_emails {
      allow read: if request.auth != null;
      allow write: if request.auth.token.isActive == true;
    }
  }
}
