# Stripped service account (default fields like type/auth_uri/token_uri/universe_domain
# are filled in by parseServiceAccount to save Lambda env var space).
# Full SA includes: type, project_id, private_key_id, private_key, client_email,
# client_id, auth_uri, token_uri, auth_provider_x509_cert_url,
# client_x509_cert_url, universe_domain
FIREBASE_SERVICE_ACCOUNT={"project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"..."}
# SSH private key for triggering backups on the VM (ED25519, single-line PEM with \n escapes).
# ED25519 keys are ~400 B vs 3.4 KB for RSA 4096.
# Generated by: bun run scripts/src/lib/setup/backup_ssh.ts
BACKUP_SSH_KEY=
