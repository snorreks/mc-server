{
  "name": "mc-server-scripts",
  "type": "module",
  "private": true,
  "scripts": {
    "setup": "bun run src/lib/setup/project.ts",
    "setup:dev": "bun run src/lib/setup/project.ts --mode=development",
    "setup:prod": "bun run src/lib/setup/project.ts --mode=production",
