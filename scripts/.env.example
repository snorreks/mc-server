# ── Required: Firebase Admin SDK ────────────────────────────────────────────
FIREBASE_SERVICE_ACCOUNT={}

# ── Minecraft Container ──────────────────────────────────────────────────────
EULA=TRUE
RCON_PASSWORD=minecraft
ENABLE_RCON=true
ALLOW_FLIGHT=true
MAX_TICK_TIME=-1
TYPE=CURSEFORGE
REMOVE_OLD_MODS=true

# Memory & JVM (optimized with ZGC for <1ms GC pauses)
MEMORY=24G
JVM_OPTS=-XX:+UseZGC -XX:+AlwaysPreTouch -XX:+ZProactive -XX:+DisableExplicitGC

# ── Modpack (CurseForge / Auto CurseForge) ──────────────────────────────────
# Uses TYPE=CURSEFORGE with CF_PAGE_URL or CF_SERVER_MOD
CF_API_KEY=
# URL of the CurseForge modpack page (for auto-updates)
CF_PAGE_URL=https://www.curseforge.com/minecraft/modpacks/valhelsia-6
# Direct URL to the server pack zip (specific version)
CF_SERVER_MOD=https://mediafilez.forgecdn.net/files/6448/193/Valhelsia-6-6.2.3-SERVER.zip

# ── Backup SSH Key (generated by scripts/src/lib/setup/backup_ssh.ts) ───────
# Stored base64-encoded (PEM has newlines which break .env parsing)
# Public key added to mc-backup user's authorized_keys on the VM
BACKUP_SSH_KEY=
