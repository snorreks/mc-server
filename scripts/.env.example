FIREBASE_SERVICE_ACCOUNT={}
CF_API_KEY=
# JVM args for the Minecraft server (optimized with ZGC)
JVM_OPTS=-XX:+UseZGC -XX:+AlwaysPreTouch -XX:+ZProactive -XX:+DisableExplicitGC
# SSH private key for triggering backups on the VM (base64-encoded PEM)
# Public key is added to the mc-backup user's authorized_keys on the VM
# Generated by: bun run scripts/src/lib/setup/backup_ssh.ts
BACKUP_SSH_KEY=
